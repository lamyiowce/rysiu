# OpenAI API key (required)
OPENAI_API_KEY=your_openai_api_key_here

# Telegram Bot
# Create a bot via @BotFather on Telegram, then get your chat_id by messaging @userinfobot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Email (for exceptional deals — score 9+)
# For Gmail: use an App Password (myaccount.google.com/apppasswords), not your login password
EMAIL_USERNAME=you@gmail.com
EMAIL_PASSWORD=your_app_password_here
EMAIL_TO=you@gmail.com      # defaults to EMAIL_USERNAME if not set
